{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "tickup": [
        "../dist/index"
      ],
      "tickup/full": [
        "../dist/full"
      ],
      "@tickup-core-src/full": [
        "../../tickup-core-final/src/full"
      ],
      "@tickup-prime-src/full": [
        "../src/full"
      ],
      "@brand/*": [
        "../src/assets/brand/*"
      ]
    },
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "moduleResolution": "bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "erasableSyntaxOnly": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "src",
    "data-generator.ts"
  ],
  "exclude": [
    "dist"
  ]
}