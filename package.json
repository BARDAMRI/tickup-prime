{
  "name": "@tickup/prime",
  "version": "1.0.0",
  "description": "TickUp Prime premium financial engine for advanced themes, Prime-tier rendering, and pro-focused chart extensions.",
  "type": "module",
  "main": "./dist/tickup.cjs.js",
  "module": "./dist/tickup.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/tickup.es.js",
      "require": "./dist/tickup.cjs.js"
    },
    "./full": {
      "types": "./dist/full.d.ts",
      "import": "./dist/tickup-full.es.js",
      "require": "./dist/tickup-full.cjs.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "documentation",
    "legal",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && npm run build:lib && npx tsc --emitDeclarationOnly",
    "build:example": "npm run build && npm install --no-audit --no-fund --prefix example && npm run build --prefix example",
    "build:lib": "TICKUP_LIB_ENTRY=index vite build && TICKUP_LIB_ENTRY=full vite build",
    "link-core": "npm link ../tickup-core-final",
    "prepublishOnly": "npm run build",
    "preview": "vite preview",
    "combine-code": "node combineFiles.cjs",
    "test": "jest"
  },
  "keywords": [
    "tickup",
    "react",
    "chart",
    "charts",
    "financial",
    "candlestick",
    "ohlc",
    "ohlcv",
    "trading",
    "canvas",
    "stock",
    "crypto",
    "typescript"
  ],
  "author": "Bar Damri",
  "license": "MIT",
  "homepage": "https://github.com/BARDAMRI/tickup-charts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BARDAMRI/tickup-charts.git"
  },
  "bugs": {
    "url": "https://github.com/BARDAMRI/tickup-charts/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "tickup": "^1.0.7",
    "react": ">=18",
    "styled-components": ">=6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react-dom": "^19.1.2",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.7.0",
    "javascript-obfuscator": "^5.4.1",
    "jest": "^29.7.0",
    "sass": "^1.89.2",
    "sass-embedded": "^1.87.0",
    "styled-components": "^6.1.19",
    "ts-jest": "^29.3.4",
    "tickup": "^1.0.7",
    "typescript": "~5.7.2",
    "vite": "^5.4.19",
    "vite-plugin-javascript-obfuscator": "^3.1.0"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "lucide-react": "^0.541.0"
  },
  "private": true
}
